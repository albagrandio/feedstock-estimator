# Streamlit secrets template.
#  - Local:  copy this file to .streamlit/secrets.toml (git-ignored) and fill it in.
#  - Cloud:  paste these keys into Streamlit Community Cloud > App > Settings > Secrets.
# NEVER commit the real values.

BING_KEY = "your-bing-maps-key"
MAPBOX_TOKEN = "your-mapbox-token"

# PostgreSQL (only needed for the Spain NR pipeline; must be reachable from the host)
DATABASE_TYPE = "postgresql"
DBAPI = "psycopg2"
USER = "your-db-user"
PASSWORD = "your-db-password"
HOST = "your-db-host"
